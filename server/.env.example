# ═══════════════════════════════════════════
#  NOQTA SERVER — Environment Variables
#  انسخ الملف ده وسميه .env وغيّر القيم
# ═══════════════════════════════════════════

# منفذ السيرفر
PORT=3000

# مفتاح التشفير — غيّره لحاجة طويلة وعشوائية
# مثال: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_string_minimum_32_chars

# مسار قاعدة البيانات
DB_PATH=./noqta.db

# بيئة التشغيل (development / production)
NODE_ENV=production
